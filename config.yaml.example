# ACP Client Plugin Configuration

# Default provider when none specified ('opencode' or 'codex')
default_provider: opencode

# Default workspace directory for new sessions
default_cwd: ~/projects

# Auto-approve all permission requests from agents
# (recommended for autonomous operation)
auto_approve: true

# Provider-specific overrides
providers:
  opencode:
    binary: ~/.opencode/bin/opencode
    # default_cwd: ~/omo  # optional per-provider workspace
  codex:
    npx: npx
    package: "@zed-industries/codex-acp"
    # default_cwd: ~/codex-projects  # optional per-provider workspace
